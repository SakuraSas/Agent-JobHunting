# Copy this file to `.env` and fill in your local values.

# LLM
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# Local storage
DATABASE_URL=sqlite:///./data/app.db
CHROMA_DIR=./data/chroma

# Local embedding model path.
# Windows example:
# EMBEDDING_MODEL=E:/UESTC/实习/LangChain_Agent/JobHunting/bge-small/bge-small-zh-v1.5
EMBEDDING_MODEL=/opt/jobhunting/bge-small/bge-small-zh-v1.5

# Keep HuggingFace libraries offline after the embedding model is downloaded.
HF_HUB_OFFLINE=1
TRANSFORMERS_OFFLINE=1
