# DeepSeek API Key 等本地环境变量
.env

# uv 创建的 Python 虚拟环境
.venv/

# Python 运行时缓存
__pycache__/
*.py[cod]

# 测试和静态检查缓存
.pytest_cache/
.ruff_cache/

# 本地 SQLite 数据库
data/app.db
data/*.db

# Chroma 本地向量索引
data/chroma/

# 用户上传的简历，后续版本会用到
data/resumes/

# VS Code 的个人配置
.vscode/

# Windows 系统文件
Thumbs.db
Desktop.ini